{
  "name": "@zevryl/mobile",
  "version": "0.1.15",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prebuild:android": "expo prebuild --platform android --clean --non-interactive",
    "patch:android-gradle": "node scripts/patch-android-gradle.cjs",
    "build:android:release": "node scripts/require-release-api-url.cjs && npm run prebuild:android && npm run patch:android-gradle && cd android && gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@expo/vector-icons": "15.1.1",
    "expo": "54.0.35",
    "expo-blur": "15.0.8",
    "expo-constants": "18.0.13",
    "expo-font": "14.0.12",
    "expo-image-picker": "17.0.11",
    "expo-linear-gradient": "15.0.8",
    "expo-secure-store": "15.0.8",
    "expo-status-bar": "3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "5.6.2"
  },
  "devDependencies": {
    "@types/react": "19.1.17",
    "typescript": "5.9.3"
  }
}
