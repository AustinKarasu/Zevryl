{
  "name": "zevryl",
  "version": "0.1.18",
  "private": true,
  "workspaces": [
    "apps/mobile",
    "services/api"
  ],
  "scripts": {
    "dev:mobile": "npm --workspace @zevryl/mobile run start",
    "dev:api": "npm --workspace @zevryl/api run dev",
    "build": "npm run typecheck",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "lint": "npm --workspaces --if-present run lint"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "js-yaml": "^4.1.1",
    "uuid": "^11.1.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "19.1.17"
  },
  "engines": {
    "node": ">=22"
  }
}
